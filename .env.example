# cmcc-cloud-alive environment variables
# Copy to .env and fill in real values.  .env is git-ignored.
# NOTE: This program connects directly to cloud PC - no http_proxy/https_proxy needed.

# ── Runtime / state ──────────────────────────────────────────────
# Default (no env needed): ~/.cmcc-cloud-alive/state.json
# Profiles: ~/.cmcc-cloud-alive/profiles/
# SCG KPI only: ~/.cmcc-cloud-alive/scg_kpi.json  (ZTE has no KPI file)
# Override state path if needed:
# CMCC_ALIVE_STATE=/tmp/cmcc_alive_state.json
# CMCC_SCG_KPI=/tmp/scg_kpi.json

# Client profile: linux | windows | mac  (default: linux)
# CMCC_ALIVE_PROFILE=linux

# ── ZTE route ────────────────────────────────────────────────────
# Target cloud-PC VM ID (default is the research target)
# CMCC_ZTE_TARGET_VMID=163c68a9-5e1e-4cba-b9bb-68ad599a8abf

# ZTE keepalive duration in seconds (default: 120)
# CCK_ZTE_KEEPALIVE_DURATION=120

# Pre-captured CAG auth template as hex (optional, for replay)
# CCK_ZTE_CAG_AUTH_TEMPLATE_HEX=

# ── SCG route ────────────────────────────────────────────────────
# Path to a local SCG keepalive binary (not bundled; provide your own if needed)
# CMCC_SCG_BINARY=

# ── ZIME native bridge ───────────────────────────────────────────
# Path to the ZIME shared library for native transport probing
# CMCC_ZIME_LIB=

# ── Product pin (optional; default OFF) ──────────────────────────
# Public / third-party use: leave CMCC_ENFORCE_PIN unset.
# Developer acceptance / LIVE harness only:
#   export CMCC_ENFORCE_PIN=1
#   export CMCC_PRODUCT_USID=<your userServiceId>
#   export CMCC_PRODUCT_VMID=<your vmId>
#   export CMCC_PRODUCT_SPU=<your spuCode>          # optional
#   export CMCC_FORBIDDEN_USID=<sku to refuse>      # optional
#   export CMCC_FORBIDDEN_SPU=<spu to refuse>       # optional
# CMCC_ENFORCE_PIN=
# CMCC_PRODUCT_USID=
# CMCC_PRODUCT_VMID=
# CMCC_PRODUCT_SPU=
# CMCC_FORBIDDEN_USID=
# CMCC_FORBIDDEN_SPU=

# ── BBS collaboration (long_keepalive_test only) ─────────────────
# Internal BBS API key and master token for posting live-run reports.
# NEVER commit real values — keep them here in your local .env only.
BBS_API_KEY=
BBS_MASTER_TOKEN=
